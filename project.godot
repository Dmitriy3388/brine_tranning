; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="BrineTraining"
run/main_scene="uid://cvmxhfives0b8"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameManager="*uid://vo5q3qosfdgr"
ProfileManager="*uid://358811hfa247"
PopupHelper="*uid://c5c4ehr8h2rvv"
BackGround="*uid://c63huftt1gauk"
TopBar="*uid://5exhgp5572r8"
EffectsManager="*uid://c2fhbrxrwncon"

[display]

window/size/viewport_width=1124
window/stretch/mode="canvas_items"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[editor_plugins]

enabled=PackedStringArray("res://addons/chromatica/plugin.cfg", "res://addons/theme_gen_save_sync/plugin.cfg")

[gui]

theme/custom_font="uid://b3otcwydyr6hi"

[input_devices]

pointing/emulate_touch_from_mouse=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
